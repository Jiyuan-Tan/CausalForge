# Independence and Conditional Independence of Counterfactual Bundles

Named shapes for expressing joint (conditional) independence of PO
counterfactual variables.  A `POCFBundle` is a heterogeneous bundle of
`RegimedVar`s over a fixed PO system, packaged into a single dependent-tuple
measurable map `jointValue : P.О© вҶ’ (вҲҖ i, type i)`.  `IndepCF` / `CondIndepCF`
then express joint (conditional) independence of a single `RegimedVar` from
such a bundle, replacing bespoke product-tuple encodings in identification
proofs.
-/

import Causalean.PO.Core.Variable
import Causalean.Mathlib.Indep
import Causalean.Mathlib.CondIndep

/-! # Independence of Counterfactual Bundles

This file packages finite heterogeneous collections of regimed
potential-outcome variables and defines independence or conditional
independence between a single regimed variable and such a bundle. These forms
provide reusable assumptions for identification theorems.

The main structure is `POCFBundle`, whose `jointValue` map turns a finite
dependent tuple of regimed potential outcomes into one measurable conditioning
object.  `POSystem.IndepCF` and `POSystem.CondIndepCF` unfold to `IndepFun` and
`CondIndepFun`, and the projection lemmas let downstream files extract
independence for a measurable function or a single coordinate of the bundle. -/

namespace Causalean
namespace PO

open MeasureTheory ProbabilityTheory

/-- A finite heterogeneous bundle of regimed potential-outcome variables, with
each coordinate carrying its own measurable value space.

Used to express joint-independence hypotheses uniformly. -/
structure POCFBundle (P : POSystem) where
  /-- Length of the bundle. -/
  n : в„•
  /-- Value type of each component. -/
  type : Fin n вҶ’ Type*
  /-- Measurable-space structure on each component. -/
  inst : вҲҖ i, MeasurableSpace (type i)
  /-- Component `RegimedVar`s. -/
  vars : вҲҖ i, RegimedVar P (type i)

namespace POCFBundle

variable {P : POSystem} (B : POCFBundle P)

/-- Each coordinate type in a counterfactual bundle carries its declared
measurable-space structure. -/
instance instMeasurableSpaceType (i : Fin B.n) : MeasurableSpace (B.type i) :=
  B.inst i

/-- The joint counterfactual-value map sends each sample point to the tuple of
all regimed counterfactual values in the bundle. -/
def jointValue : P.О© вҶ’ (вҲҖ i : Fin B.n, B.type i) :=
  fun Пү i => (B.vars i).value Пү

/-- The joint counterfactual-value map of a bundle is measurable. -/
lemma measurable_jointValue : Measurable B.jointValue :=
  measurable_pi_lambda _ (fun i => (B.vars i).measurable_value)

/-- The empty counterfactual bundle has no coordinates. -/
def nil (P : POSystem) : POCFBundle P where
  n := 0
  type := Fin.elim0
  inst := fun i => i.elim0
  vars := fun i => i.elim0

/-- Adding a regimed potential-outcome variable to the front of a bundle produces
the corresponding extended counterfactual bundle. -/
def cons {P : POSystem} {Оұ : Type*} [inst : MeasurableSpace Оұ]
    (a : RegimedVar P Оұ) (B : POCFBundle P) : POCFBundle P where
  n := B.n + 1
  type := Fin.cases Оұ B.type
  inst := Fin.cases inst B.inst
  vars := Fin.cases a B.vars

end POCFBundle

/-- A regimed potential-outcome variable is independent of a counterfactual
bundle when its value is independent of the bundle's joint counterfactual value
under the chosen measure. -/
def POSystem.IndepCF {Оұ : Type*} [MeasurableSpace Оұ] (P : POSystem)
    (a : RegimedVar P Оұ) (B : POCFBundle P) (Ој : Measure P.О© := P.Ој) : Prop :=
  IndepFun a.value B.jointValue Ој

/-- A regimed potential-outcome variable is conditionally independent of a
counterfactual bundle when its value is conditionally independent of the
bundle's joint counterfactual value given the sigma-algebra generated by the
conditioning variable.

Requires `StandardBorelSpace P.О©` for `CondIndepFun` to make sense. -/
def POSystem.CondIndepCF {Оұ Оі : Type*} [MeasurableSpace Оұ] [MeasurableSpace Оі]
    (P : POSystem) [StandardBorelSpace P.О©]
    (a : RegimedVar P Оұ) (B : POCFBundle P) (c : RegimedVar P Оі)
    (Ој : Measure P.О© := P.Ој) [IsFiniteMeasure Ој] : Prop :=
  CondIndepFun
    (MeasurableSpace.comap c.value inferInstance)
    (c.measurable_value.comap_le)
    a.value B.jointValue Ој

namespace POSystem

variable {P : POSystem}

/-- Bridge: `IndepCF` is by definition `IndepFun a.value B.jointValue Ој`. -/
lemma IndepCF.toIndepFun {Оұ : Type*} [MeasurableSpace Оұ]
    {a : RegimedVar P Оұ} {B : POCFBundle P} {Ој : Measure P.О©} :
    P.IndepCF a B Ој вҶ’ IndepFun a.value B.jointValue Ој := id

/-- Bridge: `IndepFun` вҮ’ `IndepCF` (reverse direction, also trivial). -/
lemma IndepCF.ofIndepFun {Оұ : Type*} [MeasurableSpace Оұ]
    {a : RegimedVar P Оұ} {B : POCFBundle P} {Ој : Measure P.О©} :
    IndepFun a.value B.jointValue Ој вҶ’ P.IndepCF a B Ој := id

/-- Bridge: `CondIndepCF` unfolds to `CondIndepFun` with the comap Пғ-algebra
generated by `c.value`. -/
lemma CondIndepCF.toCondIndepFun {Оұ Оі : Type*}
    [MeasurableSpace Оұ] [MeasurableSpace Оі] [StandardBorelSpace P.О©]
    {a : RegimedVar P Оұ} {B : POCFBundle P} {c : RegimedVar P Оі}
    {Ој : Measure P.О©} [IsFiniteMeasure Ој] :
    P.CondIndepCF a B c Ој вҶ’
      CondIndepFun
        (MeasurableSpace.comap c.value inferInstance)
        (c.measurable_value.comap_le)
        a.value B.jointValue Ој := id

/-- Transport `CondIndepCF` across equality of the conditioning variables'
generated Пғ-algebras. -/
theorem condIndepCF_congr_cond {Оұ Оі Оі' : Type*}
    [MeasurableSpace Оұ] [MeasurableSpace Оі] [MeasurableSpace Оі']
    [StandardBorelSpace P.О©]
    {a : RegimedVar P Оұ} {B : POCFBundle P} {c : RegimedVar P Оі}
    {c' : RegimedVar P Оі'} {Ој : Measure P.О©} [IsFiniteMeasure Ој]
    (hcomap : MeasurableSpace.comap c.value inferInstance =
      MeasurableSpace.comap c'.value inferInstance)
    (h : P.CondIndepCF a B c Ој) : P.CondIndepCF a B c' Ој := by
  unfold CondIndepCF at h вҠў
  convert h using 1
  exact hcomap.symm

/-- Projection: independence of `a.value` from any measurable function of the
bundle's joint value follows from `IndepCF`. -/
lemma IndepCF.project {Оұ ОІ : Type*} [MeasurableSpace Оұ] [MeasurableSpace ОІ]
    {a : RegimedVar P Оұ} {B : POCFBundle P} {Ој : Measure P.О©}
    {ПҲ : (вҲҖ i, B.type i) вҶ’ ОІ} (h : P.IndepCF a B Ој) (hПҲ : Measurable ПҲ) :
    IndepFun a.value (ПҲ вҲҳ B.jointValue) Ој :=
  h.toIndepFun.comp measurable_id hПҲ

/-- Component projection: independence of `a.value` from a single coordinate
of the bundle follows from `IndepCF`. -/
lemma IndepCF.component {Оұ : Type*} [MeasurableSpace Оұ]
    {a : RegimedVar P Оұ} {B : POCFBundle P} {Ој : Measure P.О©}
    (h : P.IndepCF a B Ој) (i : Fin B.n) :
    IndepFun a.value (fun Пү => B.jointValue Пү i) Ој :=
  h.project (ПҲ := fun f => f i) (measurable_pi_apply i)

/-- Projection: conditional independence of `a.value` from any measurable
function of the bundle's joint value follows from `CondIndepCF`. -/
lemma CondIndepCF.project {Оұ ОІ Оі : Type*}
    [MeasurableSpace Оұ] [MeasurableSpace ОІ] [MeasurableSpace Оі]
    [StandardBorelSpace P.О©]
    {a : RegimedVar P Оұ} {B : POCFBundle P} {c : RegimedVar P Оі}
    {Ој : Measure P.О©} [IsFiniteMeasure Ој]
    {ПҲ : (вҲҖ i, B.type i) вҶ’ ОІ} (h : P.CondIndepCF a B c Ој) (hПҲ : Measurable ПҲ) :
    CondIndepFun
        (MeasurableSpace.comap c.value inferInstance)
        (c.measurable_value.comap_le)
        a.value (ПҲ вҲҳ B.jointValue) Ој :=
  h.toCondIndepFun.comp measurable_id hПҲ

/-- Component projection: conditional independence of `a.value` from a single
coordinate of the bundle follows from `CondIndepCF`. -/
lemma CondIndepCF.component {Оұ Оі : Type*}
    [MeasurableSpace Оұ] [MeasurableSpace Оі] [StandardBorelSpace P.О©]
    {a : RegimedVar P Оұ} {B : POCFBundle P} {c : RegimedVar P Оі}
    {Ој : Measure P.О©} [IsFiniteMeasure Ој]
    (h : P.CondIndepCF a B c Ој) (i : Fin B.n) :
    CondIndepFun
        (MeasurableSpace.comap c.value inferInstance)
        (c.measurable_value.comap_le)
        a.value (fun Пү => B.jointValue Пү i) Ој :=
  h.project (ПҲ := fun f => f i) (measurable_pi_apply i)

end POSystem

end PO
end Causalean
