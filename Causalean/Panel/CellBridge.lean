# Generic finite cell bridges

Reusable probability-space infrastructure for finite partitions generated by
observable cell maps.  The main objects are one-axis and two-axis indicator
spans as `LinearL2Class` values, together with the basic cell-mass and
finite-partition integral lemmas shared by the estimand-characterization
bridge modules.

Here a **cell** is a measurable level set `{ω | G ω = g}` of an observable map
`G : Ω → 𝒢` on a probability space — *not* the discrete unit-period index
`(i, t) ∈ I × T` of `Causalean.Panel.Cells`. The two notions are independent and
neither file imports the other; the only shared substrate is
`Causalean.Panel.Weighted.IndicatorSpan`, whose finite-weighted-support versions
are re-exported below under `finite*` names.
-/

import Mathlib.MeasureTheory.Function.LpSpace.Basic
import Mathlib.MeasureTheory.Integral.Bochner.Basic
import Mathlib.MeasureTheory.Integral.Bochner.Set
import Causalean.Panel.Analysis.Residualization
import Causalean.Panel.Weighted.IndicatorSpan

/-!
Provides measure-theoretic finite-cell bridge infrastructure for panel
estimand characterizations. It defines cell indicators, indicator spans, cell
masses, and finite-partition integral lemmas for observable cell maps.
-/

namespace Causalean.Panel.CellBridge

/-! ### Finite-cell re-exports

The **finite-cell** counterparts of the measure-theoretic objects below
(`cellIndicator`, `indicatorSpan`, `twoAxisIndicatorSpan`, `cellMass`,
`jointCellMass`, `cellMean`) now live as the canonical substrate at
`Causalean/Panel/Weighted/IndicatorSpan.lean`.  We re-export them under
distinguished names so users of `CellBridge` can reach both flavours
without an extra import.

The legacy `cellMass`, `cellMean`, `cellIndicator`, `indicatorSpan`,
`twoAxisIndicatorSpan`, `jointCellMass` declared below remain the
measure-theoretic versions and are untouched. -/

/-- Finite-weighted-support cell indicator from `Causalean.Panel.Weighted.IndicatorSpan`. -/
abbrev finiteCellIndicator {R 𝒢 : Type*} [DecidableEq 𝒢]
    (G : R → 𝒢) (g : 𝒢) : R → ℝ :=
  Causalean.Panel.Weighted.cellIndicator G g

/-- Finite-weighted one-axis indicator span from
`Causalean.Panel.Weighted.IndicatorSpan`. -/
abbrev finiteIndicatorSpan {R 𝒢 : Type*} [Fintype 𝒢] [DecidableEq 𝒢]
    (G : R → 𝒢) : Submodule ℝ (R → ℝ) :=
  Causalean.Panel.Weighted.indicatorSpan G

/-- Finite-weighted two-axis indicator span from
`Causalean.Panel.Weighted.IndicatorSpan`. -/
abbrev finiteTwoAxisIndicatorSpan {R 𝒢 𝒯 : Type*}
    [Fintype 𝒢] [DecidableEq 𝒢] [Fintype 𝒯] [DecidableEq 𝒯]
    (G : R → 𝒢) (T : R → 𝒯) : Submodule ℝ (R → ℝ) :=
  Causalean.Panel.Weighted.twoAxisIndicatorSpan G T

open MeasureTheory Finset Causalean.Panel
open scoped BigOperators

/-- Real-valued singleton indicator for the cell `{X = i}`. -/
noncomputable def cellIndicator {Ω ι : Type*} [MeasurableSpace Ω]
    (X : Ω → ι) (i : ι) : Ω → ℝ :=
  fun ω => Set.indicator {ω' | X ω' = i} (fun _ => (1 : ℝ)) ω

/-- One-axis finite indicator span generated by a measurable cell map `G`.

Members are finite linear combinations of singleton indicators
`𝟙{G = g}`. -/
noncomputable def indicatorSpan {Ω 𝒢 : Type*} [MeasurableSpace Ω] [Fintype 𝒢]
    [DecidableEq 𝒢] [MeasurableSpace 𝒢] [MeasurableSingletonClass 𝒢]
    (μ : Measure Ω) [IsProbabilityMeasure μ]
    (G : Ω → 𝒢) (G_meas : Measurable G) : LinearL2Class μ := by
  classical
  refine {
    mem := fun f => ∃ c : 𝒢 → ℝ,
      f =ᵐ[μ] (fun ω =>
        ∑ g, c g * Set.indicator {ω' | G ω' = g} (fun _ => (1 : ℝ)) ω)
    , memLp := by
      intro f hf
      rcases hf with ⟨c, hfc⟩
      have hsum : MemLp
          (fun ω => ∑ g, c g
            * Set.indicator {ω' | G ω' = g} (fun _ => (1 : ℝ)) ω)
          (2 : ENNReal) μ := by
        have hsum' : ∀ s : Finset 𝒢, MemLp
            (fun ω => s.sum (fun g => c g
              * Set.indicator {ω' | G ω' = g} (fun _ => (1 : ℝ)) ω))
            (2 : ENNReal) μ := by
          intro s
          refine Finset.induction_on s ?_ ?_
          · simpa using
              (MeasureTheory.memLp_const
                (μ := μ) (p := (2 : ENNReal)) (c := (0 : ℝ)))
          · intro g s hg hs
            have hMeas : MeasurableSet {ω : Ω | G ω = g} :=
              G_meas (measurableSet_singleton g)
            have hconst : MemLp
                (fun ω =>
                  Set.indicator {ω' | G ω' = g} (fun _ => (1 : ℝ)) ω)
                (2 : ENNReal) μ :=
              (MeasureTheory.memLp_const
                (μ := μ) (p := (2 : ENNReal)) (c := (1 : ℝ))).indicator hMeas
            have hterm : MemLp
                (fun ω => c g
                  * Set.indicator {ω' | G ω' = g} (fun _ => (1 : ℝ)) ω)
                (2 : ENNReal) μ := by
              simpa [mul_comm] using hconst.const_mul (c g)
            simpa [Finset.sum_insert, hg, add_comm, add_left_comm, add_assoc]
              using hterm.add hs
        exact hsum' (Finset.univ : Finset 𝒢)
      exact (memLp_congr_ae hfc.symm).1 hsum
    , zero_mem := by
      refine ⟨fun _ => 0, ?_⟩
      filter_upwards [] with ω
      simp
    , add_mem := by
      rintro f f' ⟨c, hfc⟩ ⟨c', hfc'⟩
      refine ⟨fun g => c g + c' g, ?_⟩
      filter_upwards [hfc, hfc'] with ω hf hf'
      change f ω + f' ω =
        ∑ g, (c g + c' g)
          * Set.indicator {ω' | G ω' = g} (fun _ => (1 : ℝ)) ω
      rw [hf, hf']
      calc
        (∑ g, c g * Set.indicator {ω' | G ω' = g} (fun _ => (1 : ℝ)) ω)
            + (∑ g, c' g * Set.indicator {ω' | G ω' = g} (fun _ => (1 : ℝ)) ω)
            = ∑ g, (c g * Set.indicator {ω' | G ω' = g} (fun _ => (1 : ℝ)) ω
                    + c' g * Set.indicator {ω' | G ω' = g} (fun _ => (1 : ℝ)) ω) := by
              simpa [Finset.sum_add_distrib]
        _ = ∑ g, (c g + c' g)
            * Set.indicator {ω' | G ω' = g} (fun _ => (1 : ℝ)) ω := by
              refine Finset.sum_congr rfl (fun g _ => ?_)
              ring
    , smul_mem := by
      intro a f ⟨c, hfc⟩
      refine ⟨fun g => a * c g, ?_⟩
      filter_upwards [hfc] with ω hf
      simp [hf, Finset.mul_sum, mul_assoc, mul_left_comm, mul_comm,
        add_comm, add_left_comm, add_assoc]
  }

/-- Two-axis finite indicator span generated by measurable maps `G` and `T`.

Members are sums of a finite linear combination of `𝟙{G = g}` and a finite
linear combination of `𝟙{T = t}`. -/
noncomputable def twoAxisIndicatorSpan
    {Ω 𝒢 𝒯 : Type*} [MeasurableSpace Ω]
    [Fintype 𝒢] [DecidableEq 𝒢] [MeasurableSpace 𝒢] [MeasurableSingletonClass 𝒢]
    [Fintype 𝒯] [DecidableEq 𝒯] [MeasurableSpace 𝒯] [MeasurableSingletonClass 𝒯]
    (μ : Measure Ω) [IsProbabilityMeasure μ]
    (G : Ω → 𝒢) (T : Ω → 𝒯)
    (G_meas : Measurable G) (T_meas : Measurable T) : LinearL2Class μ := by
  classical
  refine {
    mem := fun f => ∃ (cG : 𝒢 → ℝ) (cT : 𝒯 → ℝ),
      f =ᵐ[μ] (fun ω =>
        (∑ g, cG g * Set.indicator {ω' | G ω' = g} (fun _ => (1 : ℝ)) ω)
          + (∑ t, cT t
            * Set.indicator {ω' | T ω' = t} (fun _ => (1 : ℝ)) ω))
    , memLp := by
      intro f hf
      rcases hf with ⟨cG, cT, hfc⟩
      have hsumG : MemLp
          (fun ω => ∑ g, cG g
            * Set.indicator {ω' | G ω' = g} (fun _ => (1 : ℝ)) ω)
          (2 : ENNReal) μ := by
        exact (indicatorSpan μ G G_meas).memLp
          ⟨cG, Filter.EventuallyEq.rfl⟩
      have hsumT : MemLp
          (fun ω => ∑ t, cT t
            * Set.indicator {ω' | T ω' = t} (fun _ => (1 : ℝ)) ω)
          (2 : ENNReal) μ := by
        exact (indicatorSpan μ T T_meas).memLp
          ⟨cT, Filter.EventuallyEq.rfl⟩
      have hsum : MemLp
          (fun ω =>
            (∑ g, cG g * Set.indicator {ω' | G ω' = g} (fun _ => (1 : ℝ)) ω)
              + (∑ t, cT t
                * Set.indicator {ω' | T ω' = t} (fun _ => (1 : ℝ)) ω))
          (2 : ENNReal) μ :=
        hsumG.add hsumT
      exact (memLp_congr_ae hfc.symm).1 hsum
    , zero_mem := by
      refine ⟨fun _ => 0, fun _ => 0, ?_⟩
      filter_upwards [] with ω
      simp
    , add_mem := by
      rintro f f' ⟨cG, cT, hfc⟩ ⟨cG', cT', hfc'⟩
      refine ⟨fun g => cG g + cG' g, fun t => cT t + cT' t, ?_⟩
      filter_upwards [hfc, hfc'] with ω hf hf'
      change f ω + f' ω =
        (∑ g, (cG g + cG' g)
          * Set.indicator {ω' | G ω' = g} (fun _ => (1 : ℝ)) ω)
          + (∑ t, (cT t + cT' t)
            * Set.indicator {ω' | T ω' = t} (fun _ => (1 : ℝ)) ω)
      rw [hf, hf']
      calc
        ((∑ g, cG g * Set.indicator {ω' | G ω' = g} (fun _ => (1 : ℝ)) ω)
              + (∑ t, cT t
                * Set.indicator {ω' | T ω' = t} (fun _ => (1 : ℝ)) ω))
            + ((∑ g, cG' g
                * Set.indicator {ω' | G ω' = g} (fun _ => (1 : ℝ)) ω)
              + (∑ t, cT' t
                * Set.indicator {ω' | T ω' = t} (fun _ => (1 : ℝ)) ω))
            = ((∑ g, cG g * Set.indicator {ω' | G ω' = g} (fun _ => (1 : ℝ)) ω)
              + (∑ g, cG' g
                * Set.indicator {ω' | G ω' = g} (fun _ => (1 : ℝ)) ω))
              + ((∑ t, cT t
                * Set.indicator {ω' | T ω' = t} (fun _ => (1 : ℝ)) ω)
              + (∑ t, cT' t
                * Set.indicator {ω' | T ω' = t} (fun _ => (1 : ℝ)) ω)) := by
                ring
        _ = (∑ g, (cG g
              * Set.indicator {ω' | G ω' = g} (fun _ => (1 : ℝ)) ω
                + cG' g
              * Set.indicator {ω' | G ω' = g} (fun _ => (1 : ℝ)) ω))
              + (∑ t, (cT t
                * Set.indicator {ω' | T ω' = t} (fun _ => (1 : ℝ)) ω
                  + cT' t
                * Set.indicator {ω' | T ω' = t} (fun _ => (1 : ℝ)) ω)) := by
                simp [Finset.sum_add_distrib]
        _ = (∑ g, (cG g + cG' g)
              * Set.indicator {ω' | G ω' = g} (fun _ => (1 : ℝ)) ω)
              + (∑ t, (cT t + cT' t)
                * Set.indicator {ω' | T ω' = t} (fun _ => (1 : ℝ)) ω) := by
                congr 1
                · refine Finset.sum_congr rfl (fun g _ => ?_)
                  ring
                · refine Finset.sum_congr rfl (fun t _ => ?_)
                  ring
    , smul_mem := by
      intro a f ⟨cG, cT, hfc⟩
      refine ⟨fun g => a * cG g, fun t => a * cT t, ?_⟩
      filter_upwards [hfc] with ω hf
      simp [hf, Finset.mul_sum, mul_add, mul_assoc]
  }

/-- Cell mass `(μ {G = g}).toReal`. -/
def cellMass {Ω 𝒢 : Type*} [MeasurableSpace Ω]
    (μ : Measure Ω) (G : Ω → 𝒢) (g : 𝒢) : ℝ :=
  (μ {ω | G ω = g}).toReal

/-- Joint cell mass `(μ {G = g ∧ T = t}).toReal`. -/
def jointCellMass {Ω 𝒢 𝒯 : Type*} [MeasurableSpace Ω]
    (μ : Measure Ω) (G : Ω → 𝒢) (T : Ω → 𝒯) (g : 𝒢) (t : 𝒯) : ℝ :=
  (μ {ω | G ω = g ∧ T ω = t}).toReal

/-- Cell mean of a real-valued function on a finite cell. Zero-mass cells use
Lean's totalized division convention. -/
noncomputable def cellMean {Ω 𝒢 : Type*} [MeasurableSpace Ω]
    (μ : Measure Ω) (F : Ω → ℝ) (G : Ω → 𝒢) (g : 𝒢) : ℝ :=
  (∫ ω, F ω
    * Set.indicator {ω' | G ω' = g} (fun _ => (1 : ℝ)) ω ∂μ)
    / cellMass μ G g

/-- Cell indicators are in `L²` under a probability measure. -/
theorem indicator_cell_memLp {Ω 𝒢 : Type*} [MeasurableSpace Ω]
    [MeasurableSpace 𝒢] [MeasurableSingletonClass 𝒢]
    (μ : Measure Ω) [IsProbabilityMeasure μ]
    (G : Ω → 𝒢) (G_meas : Measurable G) (g : 𝒢) :
    MemLp (fun ω => Set.indicator {ω' | G ω' = g} (fun _ => (1 : ℝ)) ω) 2 μ := by
  let s : Set Ω := G ⁻¹' ({g} : Set 𝒢)
  have hMeas : MeasurableSet s := G_meas (measurableSet_singleton g)
  change MemLp (fun ω => Set.indicator s (fun _ => (1 : ℝ)) ω) 2 μ
  exact (memLp_const (μ := μ) (1 : ℝ)).indicator hMeas

/-- Cell indicators integrate to their real cell mass. -/
theorem integral_cell_indicator_one_eq_cellMass {Ω 𝒢 : Type*}
    [MeasurableSpace Ω] [MeasurableSpace 𝒢] [MeasurableSingletonClass 𝒢]
    (μ : Measure Ω) (G : Ω → 𝒢) (G_meas : Measurable G) (g : 𝒢) :
    ∫ ω, Set.indicator {ω' | G ω' = g} (fun _ => (1 : ℝ)) ω ∂μ =
      cellMass μ G g := by
  let s : Set Ω := {ω | G ω = g}
  have hs_meas : MeasurableSet s := G_meas (measurableSet_singleton g)
  change (∫ ω, Set.indicator s (1 : Ω → ℝ) ω ∂μ) = cellMass μ G g
  rw [MeasureTheory.integral_indicator_one hs_meas]
  simp [Measure.real, cellMass, s]

/-- Dividing an indicator-weighted cell integral by a nonzero cell mass and
multiplying back recovers the numerator; on zero-mass cells the numerator is
zero because the indicator is a.e. zero. -/
theorem cell_integral_div_mul_cellMass {Ω 𝒢 : Type*}
    [MeasurableSpace Ω] [Fintype 𝒢] [DecidableEq 𝒢]
    [MeasurableSpace 𝒢] [MeasurableSingletonClass 𝒢]
    (μ : Measure Ω) [IsProbabilityMeasure μ]
    (F : Ω → ℝ) (G : Ω → 𝒢) (G_meas : Measurable G) (g : 𝒢) :
    ((∫ ω, F ω * Set.indicator {ω' | G ω' = g} (fun _ => (1 : ℝ)) ω ∂μ)
        / cellMass μ G g)
      * cellMass μ G g =
      ∫ ω, F ω * Set.indicator {ω' | G ω' = g} (fun _ => (1 : ℝ)) ω ∂μ := by
  let s : Set Ω := {ω | G ω = g}
  let A : ℝ := ∫ ω, F ω * Set.indicator s (fun _ => (1 : ℝ)) ω ∂μ
  have hs_top : μ s ≠ ⊤ := by
    exact ne_of_lt <| lt_of_le_of_lt (measure_mono (Set.subset_univ s))
      (by simpa [IsProbabilityMeasure.measure_univ])
  by_cases hmass : cellMass μ G g = 0
  · have hs_zero : μ s = 0 := by
      have hzero : (μ s).toReal = 0 := by simpa [cellMass, s] using hmass
      rcases (ENNReal.toReal_eq_zero_iff (μ s)).1 hzero with h0 | htop
      · exact h0
      · exact False.elim (hs_top htop)
    have h_not_mem : ∀ᵐ ω ∂μ, ω ∉ s := by
      rw [MeasureTheory.ae_iff]
      simpa using hs_zero
    have h_ae :
        (fun ω => F ω * Set.indicator s (fun _ => (1 : ℝ)) ω) =ᵐ[μ] 0 := by
      filter_upwards [h_not_mem] with ω hω
      simp [Set.indicator, hω]
    have hA : A = 0 := by
      simpa [A] using (integral_eq_zero_of_ae h_ae)
    simp [cellMass, s, A, hmass, hA]
  · have hAdef :
        A = ∫ ω, F ω
          * Set.indicator {ω' | G ω' = g} (fun _ => (1 : ℝ)) ω ∂μ := by
      simp [A, s]
    rw [hAdef.symm]
    field_simp [hmass]

/-- Cell mean multiplied by cell mass recovers the indicator-weighted raw
integral. -/
theorem cellMean_mul_cellMass {Ω 𝒢 : Type*}
    [MeasurableSpace Ω] [Fintype 𝒢] [DecidableEq 𝒢]
    [MeasurableSpace 𝒢] [MeasurableSingletonClass 𝒢]
    (μ : Measure Ω) [IsProbabilityMeasure μ]
    (F : Ω → ℝ) (G : Ω → 𝒢) (G_meas : Measurable G) (g : 𝒢) :
    cellMean μ F G g * cellMass μ G g =
      ∫ ω, F ω
        * Set.indicator {ω' | G ω' = g} (fun _ => (1 : ℝ)) ω ∂μ := by
  simpa [cellMean] using cell_integral_div_mul_cellMass μ F G G_meas g

/-- If a square-integrable residual is orthogonal to every cell indicator,
it is orthogonal to every finite indicator-span member. -/
theorem integral_mul_indicatorSpan_eq_zero_of_cell {Ω 𝒢 : Type*}
    [MeasurableSpace Ω] [Fintype 𝒢] [DecidableEq 𝒢]
    [MeasurableSpace 𝒢] [MeasurableSingletonClass 𝒢]
    (μ : Measure Ω) [IsProbabilityMeasure μ]
    (V : Ω → ℝ) (G : Ω → 𝒢) (G_meas : Measurable G)
    (V_memLp : MemLp V 2 μ) (c : 𝒢 → ℝ)
    (hcell : ∀ g,
      ∫ ω, V ω
          * Set.indicator {ω' | G ω' = g} (fun _ => (1 : ℝ)) ω ∂μ = 0) :
    ∫ ω, V ω
        * (∑ g, c g
          * Set.indicator {ω' | G ω' = g} (fun _ => (1 : ℝ)) ω) ∂μ = 0 := by
  let term : 𝒢 → Ω → ℝ := fun g ω =>
    V ω * (c g * Set.indicator {ω' | G ω' = g} (fun _ => (1 : ℝ)) ω)
  have hterm_int : ∀ g ∈ (Finset.univ : Finset 𝒢), Integrable (term g) μ := by
    intro g _
    have hI : MemLp
        (fun ω => Set.indicator {ω' | G ω' = g} (fun _ => (1 : ℝ)) ω)
        2 μ :=
      indicator_cell_memLp μ G G_meas g
    have hcI : MemLp
        (fun ω => c g
          * Set.indicator {ω' | G ω' = g} (fun _ => (1 : ℝ)) ω)
        2 μ := by
      simpa [mul_comm] using hI.const_mul (c g)
    exact V_memLp.integrable_mul hcI
  have hpoint :
      (fun ω => V ω
        * (∑ g, c g
          * Set.indicator {ω' | G ω' = g} (fun _ => (1 : ℝ)) ω)) =
        (fun ω => ∑ g, term g ω) := by
    funext ω
    simp [term, Finset.mul_sum]
  calc
    ∫ ω, V ω
        * (∑ g, c g
          * Set.indicator {ω' | G ω' = g} (fun _ => (1 : ℝ)) ω) ∂μ
        = ∫ ω, ∑ g, term g ω ∂μ := by rw [hpoint]
    _ = ∑ g, ∫ ω, term g ω ∂μ := by
      simpa using
        (MeasureTheory.integral_finset_sum
          (Finset.univ : Finset 𝒢) (f := term) hterm_int)
    _ = 0 := by
      refine Finset.sum_eq_zero (fun g _ => ?_)
      calc
        ∫ ω, term g ω ∂μ =
            ∫ ω, c g
              * (V ω
                * Set.indicator {ω' | G ω' = g} (fun _ => (1 : ℝ)) ω) ∂μ := by
          refine integral_congr_ae ?_
          filter_upwards [] with ω
          simp [term]
          ring
        _ = c g * ∫ ω, V ω
              * Set.indicator {ω' | G ω' = g} (fun _ => (1 : ℝ)) ω ∂μ :=
          integral_const_mul (c g) _
        _ = 0 := by simp [hcell g]

/-- If a square-integrable residual is orthogonal to every indicator on both
axes, it is orthogonal to every member of the two-axis indicator span. -/
theorem integral_mul_twoAxisIndicatorSpan_eq_zero_of_axes
    {Ω 𝒢 𝒯 : Type*} [MeasurableSpace Ω]
    [Fintype 𝒢] [DecidableEq 𝒢] [MeasurableSpace 𝒢] [MeasurableSingletonClass 𝒢]
    [Fintype 𝒯] [DecidableEq 𝒯] [MeasurableSpace 𝒯] [MeasurableSingletonClass 𝒯]
    (μ : Measure Ω) [IsProbabilityMeasure μ]
    (V : Ω → ℝ) (G : Ω → 𝒢) (T : Ω → 𝒯)
    (G_meas : Measurable G) (T_meas : Measurable T)
    (V_memLp : MemLp V 2 μ)
    (cG : 𝒢 → ℝ) (cT : 𝒯 → ℝ)
    (hG : ∀ g,
      ∫ ω, V ω * Set.indicator {ω' | G ω' = g} (fun _ => (1 : ℝ)) ω ∂μ = 0)
    (hT : ∀ t,
      ∫ ω, V ω * Set.indicator {ω' | T ω' = t} (fun _ => (1 : ℝ)) ω ∂μ = 0) :
    ∫ ω, V ω
        * ((∑ g, cG g
            * Set.indicator {ω' | G ω' = g} (fun _ => (1 : ℝ)) ω)
            + (∑ t, cT t
              * Set.indicator {ω' | T ω' = t} (fun _ => (1 : ℝ)) ω)) ∂μ
      = 0 := by
  have hGzero :
      ∫ ω, V ω
        * (∑ g, cG g
          * Set.indicator {ω' | G ω' = g} (fun _ => (1 : ℝ)) ω) ∂μ = 0 :=
    integral_mul_indicatorSpan_eq_zero_of_cell μ V G G_meas V_memLp cG hG
  have hTzero :
      ∫ ω, V ω
        * (∑ t, cT t
          * Set.indicator {ω' | T ω' = t} (fun _ => (1 : ℝ)) ω) ∂μ = 0 :=
    integral_mul_indicatorSpan_eq_zero_of_cell μ V T T_meas V_memLp cT hT
  have hGint : Integrable
      (fun ω => V ω
        * (∑ g, cG g
          * Set.indicator {ω' | G ω' = g} (fun _ => (1 : ℝ)) ω)) μ := by
    let H := indicatorSpan μ G G_meas
    have hmem : H.mem (fun ω =>
        ∑ g, cG g * Set.indicator {ω' | G ω' = g} (fun _ => (1 : ℝ)) ω) :=
      ⟨cG, Filter.EventuallyEq.rfl⟩
    exact V_memLp.integrable_mul (H.memLp hmem)
  have hTint : Integrable
      (fun ω => V ω
        * (∑ t, cT t
          * Set.indicator {ω' | T ω' = t} (fun _ => (1 : ℝ)) ω)) μ := by
    let H := indicatorSpan μ T T_meas
    have hmem : H.mem (fun ω =>
        ∑ t, cT t * Set.indicator {ω' | T ω' = t} (fun _ => (1 : ℝ)) ω) :=
      ⟨cT, Filter.EventuallyEq.rfl⟩
    exact V_memLp.integrable_mul (H.memLp hmem)
  calc
    ∫ ω, V ω
        * ((∑ g, cG g
            * Set.indicator {ω' | G ω' = g} (fun _ => (1 : ℝ)) ω)
            + (∑ t, cT t
              * Set.indicator {ω' | T ω' = t} (fun _ => (1 : ℝ)) ω)) ∂μ
        = ∫ ω, V ω
          * (∑ g, cG g
            * Set.indicator {ω' | G ω' = g} (fun _ => (1 : ℝ)) ω)
          + V ω
          * (∑ t, cT t
            * Set.indicator {ω' | T ω' = t} (fun _ => (1 : ℝ)) ω) ∂μ := by
          refine integral_congr_ae ?_
          filter_upwards [] with ω
          ring
    _ = ∫ ω, V ω
          * (∑ g, cG g
            * Set.indicator {ω' | G ω' = g} (fun _ => (1 : ℝ)) ω) ∂μ
        + ∫ ω, V ω
          * (∑ t, cT t
            * Set.indicator {ω' | T ω' = t} (fun _ => (1 : ℝ)) ω) ∂μ := by
      exact integral_add hGint hTint
    _ = 0 := by simp [hGzero, hTzero]

/-- Integrate an integrable function by summing over a finite measurable
partition generated by `G`. -/
theorem integral_eq_sum_cell {Ω 𝒢 : Type*} [MeasurableSpace Ω]
    [Fintype 𝒢] [DecidableEq 𝒢] [MeasurableSpace 𝒢]
    [MeasurableSingletonClass 𝒢]
    (μ : Measure Ω) (F : Ω → ℝ) (G : Ω → 𝒢)
    (G_meas : Measurable G) (F_int : Integrable F μ) :
    ∫ ω, F ω ∂μ =
      ∑ g, ∫ ω, F ω
        * Set.indicator {ω' | G ω' = g} (fun _ => (1 : ℝ)) ω ∂μ := by
  let term : 𝒢 → Ω → ℝ := fun g ω =>
    F ω * Set.indicator {ω' | G ω' = g} (fun _ => (1 : ℝ)) ω
  have hterm_int : ∀ g ∈ (Finset.univ : Finset 𝒢), Integrable (term g) μ := by
    intro g _
    have hG : MeasurableSet {ω : Ω | G ω = g} :=
      G_meas (measurableSet_singleton g)
    have hEq :
        term g = fun ω => Set.indicator {ω' | G ω' = g} F ω := by
      funext ω
      by_cases hω : G ω = g
      · simp [term, Set.indicator, hω]
      · simp [term, Set.indicator, hω]
    rw [hEq]
    exact F_int.indicator hG
  have hsum_ind : ∀ ω, (∑ g, Set.indicator {ω' | G ω' = g}
      (fun _ => (1 : ℝ)) ω) = 1 := by
    intro ω
    rw [Finset.sum_eq_single (G ω)]
    · simp
    · intro b _ hb
      have hne : ¬ G ω = b := fun h => hb h.symm
      simp [Set.indicator, hne]
    · intro hnot
      exact False.elim (hnot (Finset.mem_univ _))
  calc
    ∫ ω, F ω ∂μ =
        ∫ ω, F ω
          * (∑ g, Set.indicator {ω' | G ω' = g}
              (fun _ => (1 : ℝ)) ω) ∂μ := by
      refine integral_congr_ae ?_
      filter_upwards [] with ω
      simp [hsum_ind ω]
    _ = ∫ ω, ∑ g, term g ω ∂μ := by
      refine integral_congr_ae ?_
      filter_upwards [] with ω
      simp [term, Finset.mul_sum]
    _ = ∑ g, ∫ ω, term g ω ∂μ := by
      simpa using
        (MeasureTheory.integral_finset_sum
          (Finset.univ : Finset 𝒢) (f := term) hterm_int)

end Causalean.Panel.CellBridge
