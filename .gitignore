/.lake
/CausalSmith/.lake
# Any Lake build dir, incl. vendored third_party libs (e.g. third_party/optlib/.lake, ~3.8G)
.lake/

# Harness transients
.claude/scheduled_tasks.lock
.claude/worktrees/

# Crash dumps
*.stackdump

# Local JS dependencies
**/node_modules/

# LaTeX auxiliaries
*.bbl
*.synctex.gz
*.aux
*.blg
*.fls
*.fdb_latexmk
# LaTeX build log (presentation papers); regenerable
paper.log

# proper-lockfile artifacts around the study graph
CausalSmith/doc/study/.graph.lock
CausalSmith/doc/study/.graph.lock.*
# Run-scoped heartbeats for research and study runs
CausalSmith/doc/study/runs/*/.active
CausalSmith/doc/research/active/*/.active
CausalSmith/doc/research/active/*/logs/.run.active
# Disposable per-paper Lean probes created by CausalSmith agents.
CausalSmith/CausalSmith/**/tmp/
# Cross-process mutex around `lake build`
CausalSmith/.lake-build.lock
CausalSmith/.lake-build.lock.*
.lake-build.lock
.lake-build.lock.*
# Cross-process mutex serializing substrate `--study` promotions
.substrate-promote.lock
.substrate-promote.lock.*

# Build / pipeline scratch output (regenerable; not source)
build_*.log
tmpq.txt
CausalSmith/infty
CausalSmith/tools/run_logs/

# Lean toolchain (elan home) — local, machine-specific, never source
.elan/
# Hand-made refactor/split backups — regenerable, never source
*.bak
# Suffixed backup snapshots (e.g. graph.json.bak_pre_graphP1, .bak_partA, .bak-thread) — regenerable
*.bak_*
*.bak-*
*.bak.*
# Codex MCP scratch snippets
CausalSmith/_mcp_snippet_*.lean
_mcp_snippet_*.lean

# Runtime-generated MCP config placeholders (regenerated into a temp dir at run time)
CausalSmith/tools/config/*.generated.json

# NFS silly-rename lock files (transient, appear when a process holds a deleted file)
.nfs*

# Pipeline agent-I/O logs — regenerable churn, not source. Scoped to the research
# bank / presentation / active-run trees only (bank READMEs + state.json stay tracked;
# the logs/ subdir does not). Deliberately does NOT match internal/audit/**/logs/.
CausalSmith/doc/research/_bank/**/logs/
CausalSmith/doc/presentation/**/logs/
CausalSmith/doc/research/active/**/logs/

# Pipeline scratch logs: leading-underscore working logs (_codex_*, _f3_*, _f25_*, ...)
# Tracked logs (e.g. _gpt54_ab_logs/run_*.log) keep letter-leading names, so are unaffected.
_*.log
# Codex one-shot scratch (root-level .codex_<name>_out.log / _task.md pairs)
.codex_*

# Python bytecode cache
__pycache__/
.pytest_cache/

# Vite / Vitest caches (regenerable; not source)
.vite/

# Editor / local agent state — never source
.vscode/
.superpowers/
.claude/projects/

# Regenerable backup / agent-log working directories
_agent_logs/
_backups/
_papersmith_backups/
_delaunder_archive/

# Throwaway LaTeX unicode smoke-test artifacts
CausalSmith/test_unicode_title*

# Scratch / parked working dirs — regenerable, never source
.dstage_quarantine/
CausalSmith/_hidden_lean/
Causalean/doc/
