\subsection*{Q6: Recency-weighted exposure regression and misspecified decay}

\paragraph{Axes.}
DGP: \texttt{ {{ dgpName }} } (additive lag response);
Baseline: \texttt{ {{ baselineName }} };
Assignment: \texttt{ {{ assignmentName }} };
Regression: \texttt{ {{ regressionName }} } (one-index decay-weighted
exposure $E_{it}(r) = \sum_{\ell = 0}^{p} r^{\ell} D_{i, t-\ell}$);
Target: \texttt{ {{ targetName }} }.

\paragraph{Setup.}
Binary treatment, finite memory $p$, additive lag response
$\E[Y_{it} \mid D_i] = \alpha_i + \lambda_t + \sum_{\ell = 0}^{p} \tau_{\ell} D_{i, t-\ell}$.
Researcher chooses $r \in [0, 1]$ and estimates
$Y_{it} = \alpha_i + \lambda_t + \rho E_{it}(r) + u_{it}$.

\paragraph{Tasks.}
\begin{enumerate}[leftmargin=2em]
  \item FWL: derive $\rho$ as a projection of the additive lag response on
        residualized $E_{it}(r)$.
  \item Exact finite-sample formula conditional on treatment paths.
  \item Simplified population formula under iid Bernoulli$(\pi)$
        assignment.
  \item Population formula under first-order Markov assignment.
  \item Conditions under which $\rho = \sum_{\ell} \tau_{\ell}$
        (total effect), $\rho = \tau_0$ (contemporaneous effect), or a
        normalized decay-weighted average.
  \item Misspecification: if $\tau_{\ell} \propto q^{\ell}$ but the
        researcher uses $r^{\ell}$, what does $\rho$ estimate?
  \item Formalization checklist.
\end{enumerate}
