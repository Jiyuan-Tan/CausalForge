\subsection*{Q1: Minimal decontaminating history basis}

\paragraph{Axes.}
DGP: \texttt{ {{ dgpName }} }; Baseline: \texttt{ {{ baselineName }} };
Assignment: \texttt{ {{ assignmentName }} };
Regression: \texttt{ {{ regressionName }} };
Target: \texttt{ {{ targetName }} }.

\paragraph{Setup.}
First-order finite memory: $Y_{it} = Y_{it}(D_{i,t-1}, D_{it})$; binary
treatment; the untreated baseline holds. Let
$m_t(ab) = \E[Y_{it}(a, b)]$ for histories $ab \in \{00, 01, 10, 11\}$.
The target effect is the switch-on contrast
$\tau_{\mathrm{on}, t} = m_t(01) - m_t(00)$.

The researcher estimates
\begin{equation*}
  Y_{it} = \alpha_i + \lambda_t + \beta R_{it} + B_{it}\transpose \eta + u_{it},
\end{equation*}
with $R_{it} = \one\{D_{i,t-1} = 0,\ D_{it} = 1\}$ and $B_{it}$ a set of
nuisance history regressors.

\paragraph{Tasks.}
\begin{enumerate}[leftmargin=2em]
  \item Define the residualized projection coefficient $\beta(B)$ via FWL.
  \item For each candidate $B$ (empty; $\{D_{it}, D_{i, t-1}\}$;
        $\{\one\{H = 10\}, \one\{H = 11\}\}$; full saturated history with
        $00$ omitted) characterize $\beta(B)$ as a linear functional of
        the four cell means.
  \item State a theorem giving necessary and sufficient linear-algebra
        conditions for $\beta(B)$ to equal a weighted average of
        $\tau_{\mathrm{on}, t}$ with no contamination from $m_t(10)$ or
        $m_t(11)$.
  \item Step-by-step natural-language proof; do not skip residualization
        and rank/support conditions.
  \item Minimality argument or counterexample: omitting a nuisance history
        gives a contaminated $\beta(B)$.
  \item Formalization checklist for the Lean translation.
\end{enumerate}
