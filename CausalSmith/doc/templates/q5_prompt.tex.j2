\subsection*{Q5: Lead diagnostics under carry-over and serial correlation}

\paragraph{Axes.}
DGP: \texttt{ {{ dgpName }} }; Baseline: \texttt{ {{ baselineName }} };
Assignment: \texttt{ {{ assignmentName }} } (stationary first-order Markov);
Regression: \texttt{ {{ regressionName }} } (event-study with leads and lags);
Target: \texttt{ {{ targetName }} }.

\paragraph{Setup.}
First-order finite memory $Y_{it} = Y_{it}(D_{i,t-1}, D_{it})$; no
anticipation. Treatment is a stationary first-order Markov chain with
$\Pr(D_t = 1 \mid D_{t-1} = 0) = a$ and
$\Pr(D_t = 0 \mid D_{t-1} = 1) = b$. Researcher estimates
\begin{equation*}
  Y_{it} = \alpha_i + \lambda_t
  + \delta D_{i, t+1} + \gamma_0 D_{it} + \gamma_{-1} D_{i, t-1} + u_{it}.
\end{equation*}

\paragraph{Tasks.}
\begin{enumerate}[leftmargin=2em]
  \item Define no anticipation precisely in this setup.
  \item FWL: write $\delta$ as a residualized projection coefficient.
  \item Express the population limit of $\delta$ as a linear combination
        of the cell means $m_t(00), m_t(01), m_t(10), m_t(11)$.
  \item Identify at least three sufficient conditions for $\delta = 0$
        (e.g., iid treatment, additive homogeneous effects with all
        relevant lags, orthogonality of the residualized lead).
  \item Construct a small counterexample with $\delta \ne 0$ despite no
        anticipation; use explicit cell means and Markov probabilities,
        not simulation.
  \item Compare with Sun--Abraham contamination.
  \item Formalization checklist.
\end{enumerate}

\paragraph{Note.}
The placeholder theorem in
\texttt{Causalean/Panel/Theorems/Q5\_LeadDiagnostic.lean} is blocked by a
boundary-convention audit for positive offsets $D_{i, t+1}$ between
\texttt{Hist p Bool} and
\texttt{Causalean/Panel/PO/TreatmentPath.lean}, which currently only handles
non-positive lags.
