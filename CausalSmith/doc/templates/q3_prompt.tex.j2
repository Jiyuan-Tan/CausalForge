\subsection*{Q3: Clean-history local-projection DiD for reversible treatments}

\paragraph{Axes.}
DGP: \texttt{ {{ dgpName }} }; Baseline: \texttt{ {{ baselineName }} }
(parallel trends after conditioning on a clean prehistory);
Assignment: \texttt{ {{ assignmentName }} };
Regression: \texttt{ {{ regressionName }} } (long-difference outcome
$Y_{i,t+h} - Y_{i,t-1}$, encoded via the $outcomeTransform$ field);
Target: \texttt{ {{ targetName }} }.

\paragraph{Setup.}
First-order carry-over $Y_{it} = Y_{it}(D_{i,t-1}, D_{it})$. Initiation
indicator $A_{it} = \one\{D_{i,t-1} = 0,\ D_{it} = 1\}$. Horizon-$1$ target
\begin{equation*}
  \tau_1 = \E[Y_{i,t+1}(1, d_{t+1}) - Y_{i,t+1}(0, 0) \mid D_{i,t-1} = 0, D_{it} = 1].
\end{equation*}

\paragraph{Candidate control risk sets.}
\begin{enumerate}[leftmargin=2em, label=\Alph*.]
  \item Current-untreated: $D_{it} = 0$.
  \item Clean current: $D_{i,t-1} = 0$ and $D_{it} = 0$.
  \item Clean through horizon: $D_{i,t-1} = 0$, $D_{it} = 0$,
        and $D_{i,t+1} = 0$.
\end{enumerate}

\paragraph{Tasks.}
\begin{enumerate}[leftmargin=2em]
  \item Define potential outcomes carefully for histories at $t$ and $t+1$.
  \item Define an LP-DiD contrast using $Y_{i,t+1} - Y_{i,t-1}$.
  \item For each risk set $A$, $B$, $C$, state whether it identifies the
        target.
  \item Prove the positive result for the strongest valid risk set,
        step by step.
  \item Construct explicit counterexamples (cell-mean tables) showing why
        the weaker risk sets fail.
  \item Generalize to $p$-memory and horizon $h$.
  \item Formalization checklist.
\end{enumerate}
