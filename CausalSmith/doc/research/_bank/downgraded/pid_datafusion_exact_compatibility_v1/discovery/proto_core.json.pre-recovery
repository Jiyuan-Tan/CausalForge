{
  "qid": "pid_datafusion_exact_compatibility",
  "specialization": "v1",
  "cluster": "partialid",
  "symbols": [
    {
      "name": "\\(n\\)",
      "type": "integer",
      "space": "\\(\\mathbb N\\)",
      "def": "Sample-size index.",
      "role": "index"
    },
    {
      "name": "\\(d\\)",
      "type": "integer",
      "space": "\\(\\mathbb N\\)",
      "def": "Covariate dimension.",
      "role": "dimension"
    },
    {
      "name": "\\(\\mathcal X\\)",
      "type": "set",
      "space": "\\(\\mathbb R^d\\)",
      "def": "Covariate support.",
      "role": "support",
      "refs": [
        "\\(d\\)"
      ]
    },
    {
      "name": "\\(\\mathcal T\\)",
      "type": "set",
      "space": "\\(\\{0,1\\}\\)",
      "def": "Treatment-state set.",
      "role": "index set"
    },
    {
      "name": "\\(t,s,k\\)",
      "type": "indices",
      "space": "\\(t,k\\in\\mathcal T,\\ s\\in\\{0,1\\}\\)",
      "def": "Treatment and study indices.",
      "role": "indices",
      "refs": [
        "\\(\\mathcal T\\)"
      ]
    },
    {
      "name": "\\(a,b\\)",
      "type": "constants",
      "space": "\\(0<a<b<\\infty\\)",
      "def": "Known outcome-support endpoints.",
      "role": "support endpoints"
    },
    {
      "name": "\\(\\theta=(\\rho,\\gamma)\\)",
      "type": "vector",
      "space": "\\(\\Theta=[0,1]^2\\)",
      "def": "Sensitivity pair for unmeasured confounding and study exchangeability.",
      "role": "index"
    },
    {
      "name": "\\(\\varepsilon,\\alpha\\)",
      "type": "constants",
      "space": "\\(\\varepsilon\\in(0,1/2),\\ \\alpha\\in(0,1)\\)",
      "def": "Positivity and noncoverage constants.",
      "role": "constants"
    },
    {
      "name": "\\(O_i=(X_i,S_i,A_i,Y_i)\\)",
      "type": "random vector",
      "space": "\\(\\mathcal X\\times\\{0,1\\}\\times\\mathcal T\\times[a,b]\\)",
      "def": "Observed unit.",
      "role": "observation",
      "refs": [
        "\\(\\mathcal X\\)",
        "\\(\\mathcal T\\)",
        "\\(a,b\\)"
      ]
    },
    {
      "name": "\\(P,P_X,f_X\\)",
      "type": "probability laws and density",
      "space": "\\(P\\in\\mathcal P(\\mathcal X\\times\\{0,1\\}\\times\\mathcal T\\times[a,b])\\)",
      "def": "Observed law, its covariate marginal, and its Lebesgue density when it exists.",
      "role": "observed law",
      "refs": [
        "\\(\\mathcal X\\)",
        "\\(\\mathcal T\\)",
        "\\(a,b\\)"
      ]
    },
    {
      "name": "\\(Q\\)",
      "type": "probability law",
      "space": "\\(\\mathcal P(\\mathcal X\\times\\{0,1\\}\\times\\mathcal T\\times[a,b]^2)\\)",
      "def": "Latent causal law on \\(X,S,A,Y(0),Y(1)\\); the realized outcome is \\(Y(A)\\).",
      "role": "latent law",
      "refs": [
        "\\(\\mathcal X\\)",
        "\\(\\mathcal T\\)",
        "\\(a,b\\)"
      ]
    },
    {
      "name": "\\(\\pi,e_t,\\mu_{st}\\)",
      "type": "functions",
      "space": "\\(\\pi:\\mathcal X\\to[0,1],\\ e_t:\\mathcal X\\times\\{0,1\\}\\to[0,1],\\ \\mu_{st}:\\mathcal X\\to[a,b]\\)",
      "def": "Observed nuisances \\(\\pi(x)=P(S=1\\mid X=x)\\), \\(e_t(x,s)=P(A=t\\mid X=x,S=s)\\), and \\(\\mu_{st}(x)=E_P[Y\\mid X=x,S=s,A=t]\\).",
      "role": "nuisances",
      "refs": [
        "\\(P,P_X,f_X\\)",
        "\\(t,s,k\\)",
        "\\(a,b\\)"
      ]
    },
    {
      "name": "\\(c_t,q_{t0}\\)",
      "type": "functions",
      "space": "\\(\\mathcal X\\to[a,b]\\)",
      "def": "Latent means \\(c_t(x)=E_Q[Y(t)\\mid X=x,S=0,A=1-t]\\) and \\(q_{t0}(x)=E_Q[Y(t)\\mid X=x,S=0]\\).",
      "role": "latent means",
      "refs": [
        "\\(Q\\)",
        "\\(t,s,k\\)"
      ]
    },
    {
      "name": "\\(v_t^\\pm,w_t^\\pm,H_t^{\\mathrm{LRVP}},G_t^{\\mathrm{LRVP}}\\)",
      "type": "functions",
      "space": "\\(\\mathcal X\\times\\Theta\\to\\mathbb R\\)",
      "def": "Published un-clipped envelopes, signed overlap, and practical proxy.",
      "role": "comparator functionals",
      "refs": [
        "\\(\\theta=(\\rho,\\gamma)\\)"
      ]
    },
    {
      "name": "\\(C_t^\\pm,V_t^\\pm,W_t^\\pm\\)",
      "type": "functions",
      "space": "\\(\\mathcal X\\times\\Theta\\to[a,b]\\)",
      "def": "Support-clipped missing-arm, trial, and observational-mixture envelopes.",
      "role": "exact envelopes",
      "refs": [
        "\\(\\theta=(\\rho,\\gamma)\\)",
        "\\(a,b\\)"
      ]
    },
    {
      "name": "\\(C_P,\\mathcal K(P),\\mathcal M(P,\\rho,\\gamma)\\)",
      "type": "functional and sets",
      "space": "\\(C_P:\\Theta\\to[0,\\infty)\\)",
      "def": "Observed compatibility functional, its zero set, and the compatible latent-law class.",
      "role": "identified objects",
      "refs": [
        "\\(P,P_X,f_X\\)",
        "\\(Q\\)",
        "\\(\\theta=(\\rho,\\gamma)\\)"
      ]
    },
    {
      "name": "\\(m,\\nu_m,q_t^\\star,c_t^\\star\\)",
      "type": "scalar, law, and functions",
      "space": "\\(m\\in[a,b],\\ \\nu_m\\in\\mathcal P([a,b])\\)",
      "def": "Endpoint outcome kernel and measurable selector route for a latent extension.",
      "role": "extension construction",
      "refs": [
        "\\(a,b\\)",
        "\\(\\theta=(\\rho,\\gamma)\\)"
      ]
    },
    {
      "name": "\\(P^{\\mathrm{can}}\\)",
      "type": "probability law",
      "space": "\\(\\mathcal P(\\mathcal X\\times\\{0,1\\}\\times\\mathcal T\\times[a,b])\\)",
      "def": "Two-stratum cancellation witness.",
      "role": "counterexample",
      "refs": [
        "\\(\\mathcal X\\)",
        "\\(a,b\\)"
      ]
    },
    {
      "name": "\\(\\beta,B,\\mathcal H_B^\\beta,\\underline f,\\bar f,\\overline{\\mathcal P}\\)",
      "type": "regularity objects",
      "space": "\\(\\beta>d/2,\\ B>0,\\ 0<\\underline f<\\bar f<\\infty\\)",
      "def": "Hölder regularity, density bounds, and primitive observed-law class.",
      "role": "inference model",
      "refs": [
        "\\(d\\)",
        "\\(P,P_X,f_X\\)"
      ]
    },
    {
      "name": "\\(J,\\mathcal I_j,p_K,K_n\\)",
      "type": "folds and basis",
      "space": "\\(J\\ge2,\\ K=K_n\\)",
      "def": "Cross-fitting partition and normalized tensor-product spline or wavelet basis.",
      "role": "learner construction",
      "refs": [
        "\\(n\\)",
        "\\(\\mathcal X\\)"
      ]
    },
    {
      "name": "\\(\\widehat\\eta^{(-j)},\\widehat\\pi^{(-j)},\\widehat e_t^{(-j)},\\widehat\\mu_{st}^{(-j)}\\)",
      "type": "functions",
      "space": "\\(\\widehat\\eta^{(-j)}=(\\widehat\\pi^{(-j)},\\widehat e^{(-j)},\\widehat\\mu^{(-j)})\\)",
      "def": "Foldwise truncated series-logit and bounded least-squares nuisance fits.",
      "role": "learners",
      "refs": [
        "\\(J,\\mathcal I_j,p_K,K_n\\)",
        "\\(\\varepsilon,\\alpha\\)",
        "\\(a,b\\)"
      ]
    },
    {
      "name": "\\(h,\\widehat\\eta_n,\\mathfrak F,r_{\\pi,n},r_{e,n},r_{\\mu,n},F,q,v,A_0,P_n\\)",
      "type": "face, fitted vector, map, rates, constants, and law sequence",
      "space": "\\(h\\in\\{V_t^-,V_t^+,W_t^-,W_t^+\\},\\ q>4,\\ P_n\\in\\overline{\\mathcal P}\\)",
      "def": "A face functional, its cross-fitted vector, the nested functional map, error-rate labels, entropy-envelope constants, and a law sequence used only by the inference construction or question.",
      "role": "performance notation",
      "refs": [
        "\\(C_t^\\pm,V_t^\\pm,W_t^\\pm\\)",
        "\\(\\widehat\\eta^{(-j)},\\widehat\\pi^{(-j)},\\widehat e_t^{(-j)},\\widehat\\mu_{st}^{(-j)}\\)",
        "\\(\\beta,B,\\mathcal H_B^\\beta,\\underline f,\\bar f,\\overline{\\mathcal P}\\)"
      ]
    },
    {
      "name": "\\(p_s,R^\\mu_{sk},R^e_{sk},\\psi_h,\\mathcal S_n^{\\mathrm{act}}\\)",
      "type": "scores",
      "space": "\\(\\mathcal S_n^{\\mathrm{act}}\\subset L_2(P)\\)",
      "def": "Study probabilities, residual representers, face scores, and tie-retaining active-score collection.",
      "role": "orthogonal-score construction",
      "refs": [
        "\\(\\pi,e_t,\\mu_{st}\\)",
        "\\(O_i=(X_i,S_i,A_i,Y_i)\\)"
      ]
    },
    {
      "name": "\\(\\xi_i,\\mathbb G_n^\\xi,\\delta_n,\\Theta_n,h_n\\)",
      "type": "multipliers, process, and sequences",
      "space": "\\(E[\\xi_i]=0,\\ E[\\xi_i^2]=1,\\ \\delta_n\\downarrow0,\\ h_n\\downarrow0\\)",
      "def": "Multiplier process, numerical-delta step, deterministic sensitivity grid, and mesh.",
      "role": "bootstrap construction",
      "refs": [
        "\\(n\\)",
        "\\(\\theta=(\\rho,\\gamma)\\)"
      ]
    },
    {
      "name": "\\(\\widehat C_n,\\widehat C_n^\\xi,\\widehat c_{1-\\alpha},\\widehat{\\mathcal K}_{n,1-\\alpha}\\)",
      "type": "processes and random set",
      "space": "\\(\\ell^\\infty(\\Theta)\\times\\ell^\\infty(\\Theta)\\times\\mathbb R\\times\\mathcal P(\\Theta)\\)",
      "def": "Estimated functional, numerical-delta bootstrap process, critical value, and inverted outer confidence region.",
      "role": "inference objects",
      "refs": [
        "\\(\\theta=(\\rho,\\gamma)\\)",
        "\\(\\varepsilon,\\alpha\\)"
      ]
    }
  ],
  "assumptions": [
    {
      "id": "ass:iid",
      "kind": "sampling",
      "condition": "\\(O_1,\\ldots,O_n\\stackrel{\\mathrm{iid}}{\\sim}P\\).",
      "free_symbols": [
        "\\(O_i=(X_i,S_i,A_i,Y_i)\\)",
        "\\(n\\)",
        "\\(P,P_X,f_X\\)"
      ],
      "standard": {
        "name": "independent sampling",
        "cite": "ChernozhukovEtAl2018DML"
      },
      "used_by": [
        "oeq:uniform-contact-inference"
      ]
    },
    {
      "id": "ass:standard-borel",
      "kind": "measurability",
      "condition": "\\(\\mathcal X\\) is a standard-Borel space.",
      "free_symbols": [
        "\\(\\mathcal X\\)"
      ],
      "standard": {
        "name": "standard-Borel covariate space",
        "cite": "Kallenberg2002"
      },
      "used_by": [
        "oeq:exact-compatibility"
      ]
    },
    {
      "id": "ass:pushforward",
      "kind": "causal",
      "condition": "\\(\\operatorname{Law}_Q(X,S,A,Y(A))=P\\).",
      "free_symbols": [
        "\\(Q\\)",
        "\\(P,P_X,f_X\\)"
      ],
      "standard": {
        "name": "observed-data pushforward",
        "cite": "Kallenberg2002"
      },
      "used_by": [
        "lem:observational-mixture-identity",
        "prop:positive-violation-infeasibility",
        "oeq:exact-compatibility"
      ]
    },
    {
      "id": "ass:trial-randomization",
      "kind": "causal",
      "condition": "\\((Y(0),Y(1))\\perp_Q A\\mid(X,S=1)\\).",
      "free_symbols": [
        "\\(Q\\)",
        "\\(t,s,k\\)"
      ],
      "standard": {
        "name": "joint conditional trial randomization",
        "cite": "LannersRudinVolfovskyParikh2025"
      },
      "used_by": [
        "oeq:exact-compatibility"
      ]
    },
    {
      "id": "ass:relative-nuc",
      "kind": "sensitivity",
      "condition": "\\(c_t(X)\\in[C_t^-(X;\\rho),C_t^+(X;\\rho)]\\) \\(P_X\\)-almost surely for every \\(t\\in\\mathcal T\\).",
      "free_symbols": [
        "\\(c_t,q_{t0}\\)",
        "\\(C_t^\\pm,V_t^\\pm,W_t^\\pm\\)",
        "\\(P,P_X,f_X\\)",
        "\\(t,s,k\\)",
        "\\(\\mathcal T\\)"
      ],
      "standard": {
        "name": "linear relative unmeasured-confounding sensitivity model",
        "cite": "LannersRudinVolfovskyParikh2025"
      },
      "used_by": [
        "prop:positive-violation-infeasibility",
        "oeq:exact-compatibility"
      ]
    },
    {
      "id": "ass:study-exchangeability",
      "kind": "sensitivity",
      "condition": "\\(q_{t0}(X)\\in[V_t^-(X;\\gamma),V_t^+(X;\\gamma)]\\) \\(P_X\\)-almost surely for every \\(t\\in\\mathcal T\\).",
      "free_symbols": [
        "\\(c_t,q_{t0}\\)",
        "\\(C_t^\\pm,V_t^\\pm,W_t^\\pm\\)",
        "\\(P,P_X,f_X\\)",
        "\\(t,s,k\\)",
        "\\(\\mathcal T\\)"
      ],
      "standard": {
        "name": "linear study-exchangeability sensitivity model",
        "cite": "LannersRudinVolfovskyParikh2025"
      },
      "used_by": [
        "prop:positive-violation-infeasibility",
        "oeq:exact-compatibility"
      ]
    },
    {
      "id": "ass:uniform-study-positivity",
      "kind": "overlap",
      "condition": "\\(\\varepsilon\\le\\pi(X)\\le1-\\varepsilon\\) \\(P\\)-almost surely.",
      "free_symbols": [
        "\\(\\varepsilon,\\alpha\\)",
        "\\(\\pi,e_t,\\mu_{st}\\)",
        "\\(P,P_X,f_X\\)"
      ],
      "standard": {
        "name": "uniform study positivity",
        "cite": "LannersRudinVolfovskyParikh2025"
      },
      "used_by": [
        "oeq:exact-compatibility",
        "oeq:uniform-contact-inference"
      ]
    },
    {
      "id": "ass:uniform-treatment-positivity",
      "kind": "overlap",
      "condition": "\\(\\varepsilon\\le e_t(X,s)\\le1-\\varepsilon\\) \\(P\\)-almost surely for every \\(t\\in\\mathcal T\\) and \\(s\\in\\{0,1\\}\\).",
      "free_symbols": [
        "\\(\\varepsilon,\\alpha\\)",
        "\\(\\pi,e_t,\\mu_{st}\\)",
        "\\(P,P_X,f_X\\)",
        "\\(t,s,k\\)",
        "\\(\\mathcal T\\)"
      ],
      "standard": {
        "name": "uniform treatment positivity",
        "cite": "LannersRudinVolfovskyParikh2025"
      },
      "used_by": [
        "oeq:exact-compatibility",
        "oeq:uniform-contact-inference"
      ]
    },
    {
      "id": "ass:compact-support",
      "kind": "regularity",
      "condition": "\\(\\mathcal X\\subset\\mathbb R^d\\) is compact.",
      "free_symbols": [
        "\\(\\mathcal X\\)",
        "\\(d\\)"
      ],
      "standard": {
        "name": "compact covariate support",
        "cite": "ChernozhukovEtAl2018DML"
      },
      "used_by": [
        "oeq:uniform-contact-inference"
      ]
    },
    {
      "id": "ass:density-bounds",
      "kind": "regularity",
      "condition": "\\(\\underline f\\le f_X(x)\\le\\bar f\\) for Lebesgue-almost every \\(x\\in\\mathcal X\\).",
      "free_symbols": [
        "\\(\\beta,B,\\mathcal H_B^\\beta,\\underline f,\\bar f,\\overline{\\mathcal P}\\)",
        "\\(P,P_X,f_X\\)",
        "\\(\\mathcal X\\)"
      ],
      "standard": {
        "name": "density bounded above and away from zero",
        "cite": "ChernozhukovEtAl2018DML"
      },
      "used_by": [
        "oeq:uniform-contact-inference"
      ]
    },
    {
      "id": "ass:holder-nuisances",
      "kind": "regularity",
      "condition": "\\(\\pi\\in\\mathcal H_B^\\beta(\\mathcal X)\\), \\(e_t(\\cdot,s)\\in\\mathcal H_B^\\beta(\\mathcal X)\\), and \\(\\mu_{st}\\in\\mathcal H_B^\\beta(\\mathcal X)\\) for every \\(t\\in\\mathcal T\\) and \\(s\\in\\{0,1\\}\\).",
      "free_symbols": [
        "\\(\\pi,e_t,\\mu_{st}\\)",
        "\\(\\beta,B,\\mathcal H_B^\\beta,\\underline f,\\bar f,\\overline{\\mathcal P}\\)",
        "\\(\\mathcal X\\)",
        "\\(t,s,k\\)",
        "\\(\\mathcal T\\)"
      ],
      "standard": {
        "name": "uniform Hölder nuisance balls",
        "cite": "Newey1997"
      },
      "used_by": [
        "oeq:uniform-contact-inference"
      ]
    }
  ],
  "definitions": [
    {
      "id": "def:published-endpoints",
      "name": "\\(v_t^\\pm,w_t^\\pm,H_t^{\\mathrm{LRVP}},G_t^{\\mathrm{LRVP}}\\)",
      "construction": "\\(v_t^-(x;\\gamma)=(1-\\gamma)\\mu_{1t}(x)\\), \\(v_t^+(x;\\gamma)=(1+\\gamma)\\mu_{1t}(x)\\), \\(w_t^-(x;\\rho)=e_t(x,0)\\mu_{0t}(x)+e_{1-t}(x,0)(1-\\rho)\\mu_{0t}(x)\\), \\(w_t^+(x;\\rho)=e_t(x,0)\\mu_{0t}(x)+e_{1-t}(x,0)(1+\\rho)\\mu_{0t}(x)\\), \\(H_t^{\\mathrm{LRVP}}(x;\\theta)=\\min\\{v_t^+,w_t^+\\}-\\max\\{v_t^-,w_t^-\\}\\), and \\(G_t^{\\mathrm{LRVP}}(\\theta)=E_{P_X}[H_t^{\\mathrm{LRVP}}(X;\\theta)]\\), for \\(x\\in\\mathcal X\\) and \\(t\\in\\mathcal T\\).",
      "inputs": [
        "\\(\\pi,e_t,\\mu_{st}\\)",
        "\\(P,P_X,f_X\\)",
        "\\(\\theta=(\\rho,\\gamma)\\)",
        "\\(t,s,k\\)"
      ]
    },
    {
      "id": "def:exact-endpoints",
      "name": "\\(C_t^\\pm,V_t^\\pm,W_t^\\pm\\)",
      "construction": "\\(C_t^-(x;\\rho)=\\max\\{a,(1-\\rho)\\mu_{0t}(x)\\}\\), \\(C_t^+(x;\\rho)=\\min\\{b,(1+\\rho)\\mu_{0t}(x)\\}\\), \\(V_t^-(x;\\gamma)=\\max\\{a,(1-\\gamma)\\mu_{1t}(x)\\}\\), \\(V_t^+(x;\\gamma)=\\min\\{b,(1+\\gamma)\\mu_{1t}(x)\\}\\), and \\(W_t^\\pm(x;\\rho)=e_t(x,0)\\mu_{0t}(x)+e_{1-t}(x,0)C_t^\\pm(x;\\rho)\\), for \\(x\\in\\mathcal X\\), \\(t\\in\\mathcal T\\), and \\(\\theta\\in[0,1]^2\\).",
      "inputs": [
        "\\(a,b\\)",
        "\\(\\pi,e_t,\\mu_{st}\\)",
        "\\(\\theta=(\\rho,\\gamma)\\)",
        "\\(t,s,k\\)"
      ]
    },
    {
      "id": "def:compatibility-functional",
      "name": "\\(C_P,\\mathcal K(P)\\)",
      "construction": "\\(C_P(\\theta)=\\max_{t\\in\\mathcal T}E_{P_X}[(\\max\\{V_t^-(X;\\gamma),W_t^-(X;\\rho)\\}-\\min\\{V_t^+(X;\\gamma),W_t^+(X;\\rho)\\})_+]\\) and \\(\\mathcal K(P)=\\{\\theta\\in\\Theta:C_P(\\theta)=0\\}\\).",
      "inputs": [
        "\\(P,P_X,f_X\\)",
        "\\(C_t^\\pm,V_t^\\pm,W_t^\\pm\\)",
        "\\(\\mathcal T\\)",
        "\\(\\theta=(\\rho,\\gamma)\\)"
      ]
    },
    {
      "id": "def:endpoint-kernel",
      "name": "\\(\\nu_m\\)",
      "construction": "\\(\\nu_m=((b-m)/(b-a))\\delta_a+((m-a)/(b-a))\\delta_b\\) for every \\(m\\in[a,b]\\).",
      "inputs": [
        "\\(m,\\nu_m,q_t^\\star,c_t^\\star\\)",
        "\\(a,b\\)"
      ]
    },
    {
      "id": "def:selector-extension-handle",
      "name": "\\(q_t^\\star,c_t^\\star\\)",
      "construction": "For each \\(t\\in\\mathcal T\\), set \\(q_t^\\star(x;\\theta)=[\\max\\{V_t^-(x;\\gamma),W_t^-(x;\\rho)\\}+\\min\\{V_t^+(x;\\gamma),W_t^+(x;\\rho)\\}]/2\\) and \\(c_t^\\star(x;\\theta)=[q_t^\\star(x;\\theta)-e_t(x,0)\\mu_{0t}(x)]/e_{1-t}(x,0)\\). The construction route copies the observed trial arm-\\(t\\) outcome kernel to \\(Y(t)\\) under both trial assignments and, in study zero, uses \\(\\nu_{c_t^\\star(X)}\\) for each missing potential outcome, conditionally independently given \\(X,S,A\\).",
      "inputs": [
        "\\(C_t^\\pm,V_t^\\pm,W_t^\\pm\\)",
        "\\(\\pi,e_t,\\mu_{st}\\)",
        "\\(m,\\nu_m,q_t^\\star,c_t^\\star\\)",
        "\\(\\theta=(\\rho,\\gamma)\\)",
        "\\(t,s,k\\)"
      ]
    },
    {
      "id": "def:latent-class",
      "name": "\\(\\mathcal M(P,\\rho,\\gamma)\\)",
      "construction": "\\(\\mathcal M(P,\\rho,\\gamma)=\\{Q\\in\\mathcal P(\\mathcal X\\times\\{0,1\\}\\times\\mathcal T\\times[a,b]^2):\\textup{ass:pushforward}\\wedge\\textup{ass:trial-randomization}\\wedge\\textup{ass:relative-nuc}\\wedge\\textup{ass:study-exchangeability}\\}\\).",
      "by_member_properties": [
        "ass:pushforward",
        "ass:trial-randomization",
        "ass:relative-nuc",
        "ass:study-exchangeability"
      ]
    },
    {
      "id": "def:two-stratum-witness",
      "name": "\\(P^{\\mathrm{can}}\\)",
      "construction": "Let \\(\\mathcal X=\\{x_1,x_2\\}\\), \\(P^{\\mathrm{can}}(X=x_1)=4/5\\), \\(P^{\\mathrm{can}}(X=x_2)=1/5\\), and \\(P^{\\mathrm{can}}(S=s,A=t\\mid X=x_j)=1/4\\). Set \\(a=1/4\\), \\(b=8\\), \\(\\theta=(1,1)\\), \\(\\mu_{00}(x_1)=\\mu_{00}(x_2)=4\\), \\(\\mu_{10}(x_1)=1/2\\), \\(\\mu_{10}(x_2)=4\\), and \\(\\mu_{01}(x_j)=\\mu_{11}(x_j)=1\\). For every \\(j\\in\\{1,2\\}\\), \\(s\\in\\{0,1\\}\\), and \\(t\\in\\mathcal T\\), let \\(Y\\mid X=x_j,S=s,A=t\\sim\\nu_{\\mu_{st}(x_j)}\\).",
      "inputs": [
        "\\(P^{\\mathrm{can}}\\)",
        "\\(a,b\\)",
        "\\(\\pi,e_t,\\mu_{st}\\)",
        "\\(m,\\nu_m,q_t^\\star,c_t^\\star\\)",
        "\\(\\theta=(\\rho,\\gamma)\\)"
      ]
    },
    {
      "id": "def:holder-ball",
      "name": "\\(\\mathcal H_B^\\beta(\\mathcal X)\\)",
      "construction": "\\(\\mathcal H_B^\\beta(\\mathcal X)=\\{g:\\mathcal X\\to\\mathbb R:\\lVert g\\rVert_{C^\\beta(\\mathcal X)}\\le B\\}\\).",
      "inputs": [
        "\\(\\mathcal X\\)",
        "\\(\\beta,B,\\mathcal H_B^\\beta,\\underline f,\\bar f,\\overline{\\mathcal P}\\)"
      ]
    },
    {
      "id": "def:primitive-class",
      "name": "\\(\\overline{\\mathcal P}\\)",
      "construction": "\\(\\overline{\\mathcal P}=\\{P\\in\\mathcal P(\\mathcal X\\times\\{0,1\\}\\times\\mathcal T\\times[a,b]):\\textup{ass:compact-support}\\wedge\\textup{ass:density-bounds}\\wedge\\textup{ass:uniform-study-positivity}\\wedge\\textup{ass:uniform-treatment-positivity}\\wedge\\textup{ass:holder-nuisances}\\}\\).",
      "by_member_properties": [
        "ass:compact-support",
        "ass:density-bounds",
        "ass:uniform-study-positivity",
        "ass:uniform-treatment-positivity",
        "ass:holder-nuisances"
      ]
