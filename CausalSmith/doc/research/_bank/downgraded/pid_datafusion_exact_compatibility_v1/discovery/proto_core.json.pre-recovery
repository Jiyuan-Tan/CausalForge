  "estimand_functional": "\\(\\mathcal K(P)=\\{\\theta\\in[0,1]^2:C_P(\\theta)=0\\}\\), where \\(C_P(\\theta)=\\max_{t\\in\\mathcal T}E_{P_X}[(\\max\\{V_t^-,W_t^-\\}-\\min\\{V_t^+,W_t^+\\})_+]\\).",
  "target_estimand": "\\(\\mathcal K(P)\\)",
