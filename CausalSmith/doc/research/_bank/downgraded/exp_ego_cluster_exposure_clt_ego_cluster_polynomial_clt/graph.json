        "sorry_count": 0
      }
    },
    {
      "id": "lem:variance-envelope-dominates",
      "obj_id": "L-5",
      "kind": "lemma",
      "provenance": "from-note",
      "nl": {
        "statement": "For the Vbar_n construction in def:variance-envelope-handle, every realized dataset generated by an admissible finite-population array satisfies Vbar_n >= sigma_n^2.",
        "tex_anchor": "",
        "frozen": true
      },
      "lean": {
        "decl_name": null,
        "file": null
      },
