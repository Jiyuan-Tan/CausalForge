      "kind": "lemma",
      "provenance": "from-note",
      "nl": {
        "statement": "For the notation in def:variance-envelope-handle, define T_n(y)=n^{-1} sum_i sum_{r in {+,-}} s_r E_{ir} y_{ir}/pi_{ir}. For every fixed y in R^{2n}, Var_pi(T_n(y))=Q_n(y). For the true target vector y^0_{i+}=Y_in(h_n^+) and y^0_{i-}=Y_in(h_n^-), T_n(y^0)=hat_tau_HT_n and Q_n(y^0)=sigma_n^2.",
        "tex_anchor": "",
        "frozen": true
      },
      "lean": {
        "decl_name": null,
        "file": null
      },
      "review": {
        "status": "unreviewed",
        "passed_hash": null
