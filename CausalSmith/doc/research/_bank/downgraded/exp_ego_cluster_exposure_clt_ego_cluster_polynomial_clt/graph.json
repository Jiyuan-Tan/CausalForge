      }
    },
    {
      "id": "lem:uniform-oracle-wald-coverage",
      "obj_id": "L-7",
      "kind": "lemma",
      "provenance": "from-note",
      "nl": {
        "statement": "For any subclass C of def:clt-qualified-ego-incidence-array-class satisfying ass:uniform-primitive-degree-rate and any fixed alpha in (0,1), liminf_n inf_{A in C} Pr_{pi,A}{ tau_n(A) in CI_n^orc(A;1-alpha) } >= 1-alpha.",
