    {
      "id": "lem:variance-envelope-computable-attained",
      "obj_id": "L-4",
      "kind": "lemma",
      "provenance": "from-note",
      "nl": {
        "statement": "For every realized dataset generated by an array satisfying ass:exposure-consistency and ass:bounded-outcomes, the Vbar_n construction in def:variance-envelope-handle is a finite-dimensional observed-data functional and its maximum over F_n^{obs} is attained.",
        "tex_anchor": "",
        "frozen": true
      },
      "lean": {
        "decl_name": null,
        "file": null
      },
      "review": {
        "status": "unreviewed",
