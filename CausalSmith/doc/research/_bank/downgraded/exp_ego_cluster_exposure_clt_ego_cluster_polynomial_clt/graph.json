      }
    },
    {
      "id": "lem:variance-envelope-sharp",
      "obj_id": "L-6",
      "kind": "lemma",
      "provenance": "from-note",
      "nl": {
        "statement": "For the Vbar_n construction in def:variance-envelope-handle, Vbar_n is the pointwise smallest observed-data upper envelope for sigma_n^2 over bounded target-potential completions consistent with the realized target-exposure data.",
        "tex_anchor": "",
        "frozen": true
