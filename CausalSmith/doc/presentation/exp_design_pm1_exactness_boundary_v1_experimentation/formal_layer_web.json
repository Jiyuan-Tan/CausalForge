        {
          "obj_id": "prop:symmetry-reduction",
          "kind": "lemma",
          "label": "Lemma L-1",
          "nl": "Assume ass:two-block-homophily, with r in [0,infty) and kappa in [0,infty) by their definitional domains. Orbit-averaging over the full two-block automorphism group generated by permutations within A_m, permutations within B_m, and the swap of the two equal communities maps each elliptope point X with diag(X)=1 to a point in E_m^blk with weakly smaller F_{r,kappa}. The same averaging maps each law P in P_m^bal to a block-exchangeable law with the same zero one-point margins and weakly smaller F_{r,kappa}(X(P)). Consequently inf_{X : X is positive semidefinite and diag(X)=1} F_{r,kappa}(X) = inf_{X in E_m^blk} F_{r,kappa}(X) and inf_{P in P_m^bal} F_{r,kappa}(X(P)) = inf_{P in P_m^sym} F_{r,kappa}(X(P)).",
          "lean": {
            "file": "Helpers/SymmetryReduction.lean",
            "decl": "symmetry_reduction",
            "decl_kind": "lemma",
            "line": 0
          },
          "status": "matched",
          "sorry_free": true
        },
        {
          "obj_id": "lem:block-spectral-coordinates",
          "kind": "lemma",
          "label": "Lemma L-2",
          "nl": "Let q=2(m-1). For X(u,v), define x=1-u, y=1+(m-1)u-mv, and z=1+(m-1)u+mv. Then X(u,v) belongs to E_m^blk if and only if x,y,z>=0 and qx+y+z=2m. In these coordinates X_cut=(0,2m,0), I_n=(1,1,1), and F_{r,kappa}(X(u,v))=c_x x+c_y y+c_z z+kappa sqrt(qx^2+y^2+z^2), where c_x=q((a+b)+r/(a+b)), c_y=2b+r/(2b), and c_z=2m.",
          "lean": {
            "file": "Helpers/SpectralCoordinates.lean",
            "decl": "block_spectral_coordinates",
            "decl_kind": "lemma",
            "line": 0
          },
          "status": "matched",
          "sorry_free": true
        },
        {
          "obj_id": "lem:cut-vertex-certificate",
          "kind": "lemma",
          "label": "Lemma L-3",
          "nl": "On T_m={x,y,z>=0: qx+y+z=2m}, if c_x/q>c_y+kappa and c_z>c_y+kappa, then (0,2m,0) is the unique minimizer of c_x x+c_y y+c_z z+kappa sqrt(qx^2+y^2+z^2).",
          "lean": {
            "file": "Helpers/VertexCertificates.lean",
            "decl": "cut_vertex_certificate",
            "decl_kind": "lemma",
            "line": 0
          },
          "status": "matched",
          "sorry_free": true
        },
        {
          "obj_id": "lem:spread-vertex-certificate",
          "kind": "lemma",
          "label": "Lemma L-4",
          "nl": "On T_m={x,y,z>=0: qx+y+z=2m}, if c_y>c_x/q+kappa/sqrt(q) and c_z>c_x/q+kappa/sqrt(q), then (2m/q,0,0) is the unique minimizer of c_x x+c_y y+c_z z+kappa sqrt(qx^2+y^2+z^2).",
          "lean": {
            "file": "Helpers/VertexCertificates.lean",
            "decl": "spread_vertex_certificate",
