          "obj_id": "lem:bernoulli-mean-channel-kl",
          "kind": "lemma",
          "label": "Lemma L-1",
          "nl": "Fix B>0. Let Q_u and Q_v be distributions on {-B,B} with means u and v, respectively, so Q_u(B)=(1+u/B)/2 and Q_v(B)=(1+v/B)/2. If |u|<=B/2 and |v|<=B/2, then KL(Q_u,Q_v) <= 2*(u-v)^2/B^2.",
          "lean": {
            "file": "Helpers/Divergence.lean",
            "decl": "CausalSmith.Stat.DoseResponseMinimax.bernoulli_mean_channel_kl_source",
