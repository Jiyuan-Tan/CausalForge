        },
        {
          "obj_id": "lem:le-cam-two-point-mse-source",
          "kind": "lemma",
          "label": "Lemma L-2",
          "nl": "Let Q_0 and Q_1 be two laws for the n-sample experiment and let theta_0,theta_1 be the corresponding values of a real parameter, with Delta=|theta_1-theta_0|. If KL(Q_0,Q_1)<=K<infinity, then every estimator T satisfies max_{i=0,1} E_{Q_i}[(T-theta_i)^2] >= c_K Delta^2 for a constant c_K>0 depending only on K.",
          "lean": {
            "file": "Helpers/Divergence.lean",
            "decl": "CausalSmith.Stat.DoseResponseMinimax.le_cam_two_point_mse_source",
