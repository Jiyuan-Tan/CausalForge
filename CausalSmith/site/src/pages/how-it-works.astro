            <!-- edges: solid = statement-uses, dashed = proof-uses -->
            <line x1="80" y1="235" x2="80" y2="171" stroke="#6b655d" stroke-width="1" marker-end="url(#lgArrow)" />
            <line x1="240" y1="235" x2="240" y2="171" stroke="#6b655d" stroke-width="1" marker-end="url(#lgArrow)" />
            <line x1="215" y1="235" x2="106" y2="169" stroke="#6b655d" stroke-width="1" marker-end="url(#lgArrow)" />
            <line x1="240" y1="140" x2="240" y2="76" stroke="#6b655d" stroke-width="1" marker-end="url(#lgArrow)" />
            <line x1="400" y1="235" x2="400" y2="171" stroke="#6b655d" stroke-width="1" stroke-dasharray="4 3" marker-end="url(#lgArrow)" />
            <line x1="106" y1="141" x2="215" y2="76" stroke="#6b655d" stroke-width="1" stroke-dasharray="4 3" marker-end="url(#lgArrow)" />
            <line x1="374" y1="141" x2="266" y2="76" stroke="#6b655d" stroke-width="1" stroke-dasharray="4 3" marker-end="url(#lgArrow)" />

            <!-- bottom row -->
            <g>
