              <marker id="lgArrow" markerWidth="7" markerHeight="7" refX="5.5" refY="3" orient="auto">
                <path d="M0,0 L6,3 L0,6 Z" fill="#6b655d" />
              </marker>
            </defs>

            <!-- critical path underlay: setup → gated A1 → theorem T -->
