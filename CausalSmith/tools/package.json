{
  "name": "@autoid/causalsmith",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "bin": {
    "causalsmith": "./bin/causalsmith.ts"
  },
  "scripts": {
    "check": "npm run typecheck && npm test",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --no-isolate --no-file-parallelism --maxWorkers=1",
    "search": "node --import tsx/esm bin/causalean_search.ts",
    "doc:gen": "node --import tsx/esm bin/library_doc_gen.ts --write",
    "doc:check": "node --import tsx/esm bin/library_doc_gen.ts --check",
    "lint:crosswalks": "tsx bin/check_bank_crosswalks.ts",
    "lint:consistency": "tsx bin/check_kb_consistency.ts",
    "lint:kb": "npm run lint:crosswalks && npm run lint:consistency",
    "lint:kb:strict": "tsx bin/check_bank_crosswalks.ts --strict; a=$?; tsx bin/check_kb_consistency.ts --strict; b=$?; exit $(( a || b ))",
    "embed:library": "python3 scripts/embed_library.py && python3 scripts/embed_library.py --view nbr",
    "lint:embeddings": "python3 scripts/check_embeddings_fresh.py",
    "eval:retrieval": "tsx bin/retrieval_eval.ts",
    "eval:premise": "tsx bin/premise_eval.ts"
  },
  "dependencies": {
    "execa": "^9.6.0",
    "proper-lockfile": "^4.1.2",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/proper-lockfile": "^4.1.4",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "engines": {
    "node": ">=20.20.2"
  }
}
